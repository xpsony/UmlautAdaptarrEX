# UmlautAdaptarrEX — environment template.
# Copy to `.env`. For Docker, place it next to your docker-compose file (Compose
# loads it automatically). For bare-metal / local dev, place it at the repo root.
# Uncomment and edit only what you need.

# ── Local / bare-metal dev (NOT needed for Docker: the image bakes these in) ──
# DATABASE_URL is required when running outside Docker (pnpm dev / pnpm prod).
DATABASE_URL="file:./data/umlautadaptarrex.db"
NODE_ENV="development"
# When NODE_ENV != "production" the admin session TTL is 365 days (vs 14 in
# prod), so /setup or /login lasts effectively forever during local dev.

# ── Service ports ────────────────────────────────────────────────────────────
# Defaults shown. Each var sets BOTH the in-container bind port and the
# published host port (the compose mapping uses the same value on both sides).
#
# Fastify public API + legacy indexer API (/<apiKey>/<host>/api) + WS log stream.
# This is the port your *Arr apps / Prowlarr point at.
#UMLAUTADAPTARREX_LEGACYAPI_PORT=5005
#
# Next.js Web UI (open this in your browser).
#UMLAUTADAPTARREX_WEBUI_PORT=5007
#
# TCP HTTP proxy for Prowlarr indexers. When set, this OVERRIDES the value
# stored in the database at every start, and the Settings UI shows the field
# read-only.
#UMLAUTADAPTARREX_PROXY_PORT=5006

# ── Image (release compose only) ─────────────────────────────────────────────
#UMLAUTADAPTARREX_IMAGE=lexfi/umlautadaptarrex:latest

# ── Misc ─────────────────────────────────────────────────────────────────────
#TZ=Europe/Berlin
#PUID=1000
#PGID=1000
# Pino log level: trace, debug, info, warn, error, fatal. Defaults to info.
#LOG_LEVEL=info
