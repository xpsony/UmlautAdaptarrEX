{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "type": "shell",
      "command": "pnpm dev",
      "isBackground": true,
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm typecheck",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint",
      "group": "test",
      "presentation": { "reveal": "always" },
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "lint:fix",
      "type": "shell",
      "command": "pnpm exec eslint --fix src",
      "presentation": { "reveal": "always" },
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "format",
      "type": "shell",
      "command": "pnpm exec prettier --write .",
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "format:check",
      "type": "shell",
      "command": "pnpm exec prettier --check .",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm test",
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "test:e2e",
      "type": "shell",
      "command": "pnpm test:e2e",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "prisma:migrate",
      "type": "shell",
      "command": "pnpm prisma:migrate",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "prisma:studio",
      "type": "shell",
      "command": "pnpm prisma:studio",
      "isBackground": true,
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "verify all (typecheck + lint + test)",
      "dependsOrder": "sequence",
      "dependsOn": ["typecheck", "lint", "test"],
      "problemMatcher": []
    }
  ]
}
