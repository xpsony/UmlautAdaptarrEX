{
  "name": "umlautadaptarrex",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Umlaut/German-title proxy for Sonarr/Radarr/Lidarr/Readarr",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate && prisma migrate deploy",
    "dev": "concurrently -k -n server,ui -c green,blue \"pnpm dev:server\" \"pnpm dev:next\"",
    "dev:next": "next dev --port 5007 --hostname 127.0.0.1",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "pnpm build:next && pnpm build:server",
    "build:next": "next build",
    "build:server": "tsup",
    "build:prod": "cross-env NODE_ENV=production pnpm build",
    "start": "node start.mjs",
    "start:prod": "cross-env NODE_ENV=production node start.mjs",
    "prod": "pnpm build:prod && pnpm prisma:deploy && pnpm start:prod",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf .next dist coverage test-results tsconfig.tsbuildinfo node_modules/.cache && find . -name .DS_Store -not -path './node_modules/*' -not -path './.git/*' -delete"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.101.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.8.5",
    "lru-cache": "^11.5.1",
    "lucide-react": "^1.17.0",
    "moviedb-promise": "^4.0.8",
    "nanoid": "^5.1.11",
    "next": "^16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "undici": "^8.3.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
