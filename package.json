{
  "name": "umlautadaptarrex",
  "version": "2.0.0-alpha.1",
  "private": true,
  "type": "module",
  "description": "Umlaut/German-title proxy for Sonarr/Radarr/Lidarr/Readarr",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate && prisma migrate deploy",
    "dev": "concurrently -k -n server,ui -c green,blue \"pnpm dev:server\" \"pnpm dev:next\"",
    "dev:next": "next dev --port 5007 --hostname 127.0.0.1",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "pnpm build:next && pnpm build:server",
    "build:next": "next build",
    "build:server": "tsup",
    "start": "node start.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.9",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.7.3",
    "fastify": "^5.8.5",
    "lru-cache": "^11.3.6",
    "lucide-react": "^1.16.0",
    "moviedb-promise": "^4.0.8",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "undici": "^8.2.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "argon2",
      "better-sqlite3",
      "prisma"
    ],
    "overrides": {
      "postcss@<8.5.10": "^8.5.14",
      "@hono/node-server@<1.19.13": "^1.19.13"
    }
  }
}
